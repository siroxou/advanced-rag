# Copy to .env and adjust. The SAME file shape serves both runtime profiles;
# only the values differ between local (MacBook/Ollama) and cloud (vLLM/Modal).

# --- App ---
APP_NAME="Enterprise Agentic RAG"
ENVIRONMENT=local                 # local | cloud
LOG_LEVEL=INFO

# --- LLM (OpenAI-compatible) ---
# LOCAL     : Ollama serving Gemma 4 on Apple Metal.
# CLOUD     : point LLM_BASE_URL at your vLLM endpoint; set LLM_PROVIDER=vllm.
# OPENROUTER: LLM_PROVIDER=openrouter + LLM_BASE_URL=https://openrouter.ai/api/v1,
#             then pick any model (e.g. anthropic/claude-haiku-4.5). One gateway
#             fronts OpenAI / Anthropic / Google / many models.
LLM_PROVIDER=ollama
LLM_MODEL=gemma4:latest
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_ENABLE_THINKING=false         # Gemma 4 reasoning; off = fast, final answers only
# Shared OpenRouter key for the hosted demo. Leave empty locally. Users can also
# set their own key from the Settings page (which lifts the demo rate limit).
OPENROUTER_API_KEY=
# Generation defaults (runtime-overridable from the Settings page).
GEN_TEMPERATURE=0.2
GEN_MAX_TOKENS=1024

# --- Embeddings / retrieval (Phase 1) ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024                 # must match the migration's vector(...) column
EMBEDDING_DEVICE=auto             # auto -> mps on Apple Silicon, else cpu
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CHUNK_CHARS=1800                  # target chunk size (~450 tokens)
CHUNK_OVERLAP=200
RETRIEVAL_CANDIDATES=40           # hybrid pool size before rerank
RETRIEVAL_TOP_K=6                 # chunks kept after rerank and sent to the LLM
RRF_K=60                          # reciprocal-rank-fusion constant
DEFAULT_ROLES=viewer             # request roles until Phase 2 wires JWT-derived roles

# --- Database (Phase 1+): Postgres + pgvector ---
# LOCAL : docker compose up  ->  localhost:5432
# CLOUD : managed Neon/Supabase connection string
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag
# The app's DB role must NOT be a superuser (superusers bypass Row-Level Security).

# --- Auth (Phase 2): JWT ---
# CHANGE in production. Roles live in the signed token and drive Postgres RLS.
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# --- Web search (Phase 3) ---
TAVILY_API_KEY=

# --- Guardrails (Phase 4) ---
# GUARDRAILS_ENABLED is the master kill switch; the per-guardrail toggles below are
# AND-ed with it. All are runtime-overridable from the Settings page.
GUARDRAILS_ENABLED=true
GUARDRAILS_INJECTION=true
GUARDRAILS_GROUNDING=true
GUARDRAILS_PII_DETECT=true
GUARDRAILS_SAFETY=true
GUARDRAILS_PII_MASK=false         # mask detected PII in answers (not just flag it)
# Optional ShieldGemma-style safety model (served like the main LLM). Empty = skip
# safety classification; injection + grounding + PII checks still run.
GUARDRAILS_SAFETY_MODEL=

# --- Rate limiting ---
# Protects the shared demo OpenRouter key; only enforced when a request would spend
# it (skipped for local providers and bring-your-own keys). Runtime-overridable.
RATELIMIT_ENABLED=true
RATELIMIT_PER_MINUTE=1

# --- Observability (Phase 6): LangFuse ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:3000
