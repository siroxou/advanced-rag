# Copy to .env and adjust. The SAME file shape serves both runtime profiles;
# only the values differ between local (MacBook/Ollama) and cloud (vLLM/Modal).

# --- App ---
APP_NAME="Enterprise Agentic RAG"
ENVIRONMENT=local                 # local | cloud
LOG_LEVEL=INFO

# --- LLM (OpenAI-compatible) ---
# LOCAL  : Ollama serving Gemma 4 on Apple Metal.
# CLOUD  : point LLM_BASE_URL at your vLLM endpoint; set LLM_PROVIDER=vllm.
LLM_PROVIDER=ollama
LLM_MODEL=gemma4:latest
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_ENABLE_THINKING=false         # Gemma 4 reasoning; off = fast, final answers only

# --- Embeddings / retrieval (Phase 1) ---
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5

# --- Database (Phase 1+): Postgres + pgvector ---
# LOCAL : docker compose up  ->  localhost:5432
# CLOUD : managed Neon/Supabase connection string
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag

# --- Web search (Phase 3) ---
TAVILY_API_KEY=

# --- Observability (Phase 6): LangFuse ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:3000
